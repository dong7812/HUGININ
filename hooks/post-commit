#!/usr/bin/env bash
# HUGININ post-commit hook — collab-proof 기반 고도화
# CI 환경, session.lock, hash-map.json 관리

set -euo pipefail

HUGININ_DIR=".huginin"
LOCK_FILE="$HUGININ_DIR/session.lock"
HASH_MAP="$HUGININ_DIR/hash-map.json"

# CI/CD 환경 자동 스킵
if [ "${CI:-false}" = "true" ] || [ "${GITHUB_ACTIONS:-false}" = "true" ]; then
  exit 0
fi

# huginin CLI 미설치 시 스킵
if ! command -v huginin &>/dev/null; then
  exit 0
fi

# 토큰 미설정 시 스킵
TOKEN=$(huginin __token 2>/dev/null || true)
if [ -z "$TOKEN" ]; then
  exit 0
fi

mkdir -p "$HUGININ_DIR"

# 동시 실행 방지 (session.lock)
if [ -f "$LOCK_FILE" ]; then
  LOCK_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
  if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
    echo "[huginin] another session running (pid $LOCK_PID), skipping"
    exit 0
  fi
fi
echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# 커밋 정보 수집
COMMIT_HASH=$(git rev-parse HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)
DIFF=$(git diff HEAD~1 HEAD --stat 2>/dev/null | head -50 || git diff --cached --stat | head -50)

# hash-map.json: rebase/amend 시 원본 해시 보존
if [ -f "$HASH_MAP" ]; then
  ORIG_HASH=$(python3 -c "
import json, sys
d = json.load(open('$HASH_MAP'))
print(d.get('$COMMIT_HASH', '$COMMIT_HASH'))
" 2>/dev/null || echo "$COMMIT_HASH")
else
  echo '{}' > "$HASH_MAP"
  ORIG_HASH="$COMMIT_HASH"
fi

# .huginin/projects.json 에서 workspace/project 설정 읽기
PROJECTS_FILE="$HUGININ_DIR/projects.json"
if [ ! -f "$PROJECTS_FILE" ]; then
  echo "[huginin] not linked — run: huginin project link"
  exit 0
fi

WORKSPACE_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('workspace_id',''))" 2>/dev/null || true)
PROJECT_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('project_id',''))" 2>/dev/null || true)

if [ -z "$WORKSPACE_ID" ]; then
  echo "[huginin] workspace_id not set in $PROJECTS_FILE"
  exit 0
fi

# ── Claude Code 세션 로그에서 대화 추출 ──────────────────────────────────────
# 우선순위:
#   1. .huginin/active-jsonl — huginin multiplexer가 현재 세션에 핀한 경로
#   2. ~/.claude/projects/ 내 30분 내 수정된 가장 최근 JSONL
ACTIVE_JSONL=""

# 1순위: huginin multiplexer가 핀한 active-jsonl (가장 정확)
if [ -f "$HUGININ_DIR/active-jsonl" ]; then
  CANDIDATE=$(cat "$HUGININ_DIR/active-jsonl" 2>/dev/null || true)
  if [ -n "$CANDIDATE" ] && [ -f "$CANDIDATE" ]; then
    ACTIVE_JSONL="$CANDIDATE"
  fi
fi

# 2순위: 현재 repo 경로를 인코딩해서 해당 프로젝트 전용 Claude Code 디렉토리에서 최신 JSONL
# (Claude Code는 CWD를 '/'→'-' 인코딩해서 ~/.claude/projects/<encoded>/ 에 세션을 저장함)
if [ -z "$ACTIVE_JSONL" ]; then
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
  ENCODED=$(echo "$REPO_ROOT" | tr '/' '-')
  PROJECT_CLAUDE_DIR="$HOME/.claude/projects/$ENCODED"
  if [ -d "$PROJECT_CLAUDE_DIR" ]; then
    ACTIVE_JSONL=$(ls -t "$PROJECT_CLAUDE_DIR"/*.jsonl 2>/dev/null | head -1 || true)
  fi
fi

# 3순위: 어디서도 못 찾으면 30분 내 전체 최신 JSONL (부정확할 수 있음)
if [ -z "$ACTIVE_JSONL" ]; then
  CLAUDE_LOG_DIR="$HOME/.claude/projects"
  if [ -d "$CLAUDE_LOG_DIR" ]; then
    ACTIVE_JSONL=$(find "$CLAUDE_LOG_DIR" -name "*.jsonl" -mmin -30 2>/dev/null \
      | xargs ls -t 2>/dev/null | head -1 || true)
  fi
fi

# 최근 10턴을 [DEV]/[AI] 대화 형식으로 추출
PROMPT=""
if [ -n "$ACTIVE_JSONL" ] && [ -f "$ACTIVE_JSONL" ]; then
  PROMPT=$(python3 -c "
import json

def extract_text(content):
    if isinstance(content, str):
        return content.strip()
    if isinstance(content, list):
        parts = []
        for x in content:
            if isinstance(x, dict) and x.get('type') == 'text' and x.get('text'):
                parts.append(x['text'].strip())
        return ' '.join(parts)
    return ''

turns = []
with open('$ACTIVE_JSONL') as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except Exception:
            continue
        t = entry.get('type', '')
        if t not in ('user', 'assistant'):
            continue
        content = entry.get('message', {}).get('content', '')
        # content가 list인 경우 text 블록만 있는지 확인 (tool_use/tool_result 제외)
        if isinstance(content, list):
            types = {x.get('type', '') for x in content if isinstance(x, dict)}
            if types and 'text' not in types:
                continue  # tool 전용 턴 제외
        text = extract_text(content)
        if not text:
            continue
        tag = '[DEV]' if t == 'user' else '[AI]'
        turns.append((tag, text))

recent = turns[-10:]
parts = [f'{tag} {text[:1500]}' for tag, text in recent]
print('\n\n'.join(parts)[:6000])
" 2>/dev/null || true)
fi

# 대화를 못 읽었으면 커밋 메시지로 대체
if [ -z "$PROMPT" ]; then
  PROMPT="[git commit] $COMMIT_MSG"
fi
# full-conversation 모드([DEV]/[AI] 형식)에서 refiner는 prompt만 사용함.
# 레거시 단일턴 fallback도 response를 비워두면 refiner가 prompt를 그대로 씀.
RESPONSE=""

# 비동기 업로드 (CLI 블로킹 없이)
(huginin __collect \
  --workspace "$WORKSPACE_ID" \
  --project "$PROJECT_ID" \
  --commit "$ORIG_HASH" \
  --prompt "$PROMPT" \
  --response "$RESPONSE" \
  --diff "$DIFF" \
  2>>"$HUGININ_DIR/collect.log" || true) &

echo "[huginin] event queued for commit $COMMIT_HASH"
