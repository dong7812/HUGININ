#!/usr/bin/env bash
# HUGININ post-commit hook — collab-proof 기반 고도화
# CI 환경, session.lock, hash-map.json 관리

set -euo pipefail

HUGININ_DIR=".huginin"
LOCK_FILE="$HUGININ_DIR/session.lock"
HASH_MAP="$HUGININ_DIR/hash-map.json"

# CI/CD 환경 자동 스킵
if [ "${CI:-false}" = "true" ] || [ "${GITHUB_ACTIONS:-false}" = "true" ]; then
  exit 0
fi

# huginin CLI 미설치 시 스킵
if ! command -v huginin &>/dev/null; then
  exit 0
fi

# 토큰 미설정 시 스킵
TOKEN=$(huginin __token 2>/dev/null || true)
if [ -z "$TOKEN" ]; then
  exit 0
fi

mkdir -p "$HUGININ_DIR"

# 동시 실행 방지 (session.lock)
if [ -f "$LOCK_FILE" ]; then
  LOCK_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
  if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
    echo "[huginin] another session running (pid $LOCK_PID), skipping"
    exit 0
  fi
fi
echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# 커밋 정보 수집
COMMIT_HASH=$(git rev-parse HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)
DIFF=$(git diff HEAD~1 HEAD --stat 2>/dev/null | head -50 || git diff --cached --stat | head -50)

# hash-map.json: rebase/amend 시 원본 해시 보존
if [ -f "$HASH_MAP" ]; then
  ORIG_HASH=$(python3 -c "
import json, sys
d = json.load(open('$HASH_MAP'))
print(d.get('$COMMIT_HASH', '$COMMIT_HASH'))
" 2>/dev/null || echo "$COMMIT_HASH")
else
  echo '{}' > "$HASH_MAP"
  ORIG_HASH="$COMMIT_HASH"
fi

# .huginin/projects.json 에서 workspace/project 설정 읽기
PROJECTS_FILE="$HUGININ_DIR/projects.json"
if [ ! -f "$PROJECTS_FILE" ]; then
  echo "[huginin] not linked — run: huginin project link"
  exit 0
fi

WORKSPACE_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('workspace_id',''))" 2>/dev/null || true)
PROJECT_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('project_id',''))" 2>/dev/null || true)

if [ -z "$WORKSPACE_ID" ]; then
  echo "[huginin] workspace_id not set in $PROJECTS_FILE"
  exit 0
fi

# Claude Code 세션 로그에서 전체 대화 추출 (best-effort)
# 마지막 1쌍이 아니라 세션 전체 DEV/AI 턴을 포맷해서 넘김
CLAUDE_LOG_DIR="$HOME/.claude/projects"
PROMPT=""
RESPONSE=""
if [ -d "$CLAUDE_LOG_DIR" ]; then
  LATEST=$(find "$CLAUDE_LOG_DIR" -name "*.jsonl" -mmin -1440 2>/dev/null \
    | xargs ls -t 2>/dev/null | head -1 || true)
  if [ -n "$LATEST" ]; then
    PROMPT=$(python3 -c "
import json, sys

lines = [json.loads(l) for l in open('$LATEST') if l.strip()]

turns = []
for l in lines:
    if l.get('type') not in ('user', 'assistant'):
        continue
    msg = l.get('message', {})
    role = msg.get('role')
    content = msg.get('content', '')

    if isinstance(content, str):
        text = content.strip()
    elif isinstance(content, list):
        parts = []
        for c in content:
            if not isinstance(c, dict):
                continue
            # tool_use / tool_result 제외, 순수 텍스트만
            if c.get('type') == 'text':
                t = c.get('text', '').strip()
                if t:
                    parts.append(t)
        text = '\n'.join(parts)
    else:
        text = ''

    if text and len(text) > 10:
        turns.append((role, text))

# 연속 같은 role 병합
merged = []
for role, text in turns:
    if merged and merged[-1][0] == role:
        merged[-1][1] += '\n' + text
    else:
        merged.append([role, text])

# DEV/AI 레이블로 대화 포맷팅, 각 턴 600자 제한
out = []
for role, text in merged:
    label = 'DEV' if role == 'user' else 'AI'
    out.append(f'[{label}] {text[:600]}')

conversation = '\n\n'.join(out)
# 최근 8000자 (가장 의사결정이 많은 최신 맥락)
print(conversation[-8000:])
" 2>/dev/null || true)
    # RESPONSE는 더 이상 별도로 추출하지 않음 (PROMPT에 전체 대화 포함)
    RESPONSE=""
  fi
fi

# 세션을 찾지 못하면 커밋 메시지로 대체
if [ -z "$PROMPT" ]; then
  PROMPT="[git commit] $COMMIT_MSG"
fi

# 비동기 업로드 (CLI 블로킹 없이)
(huginin __collect \
  --workspace "$WORKSPACE_ID" \
  --project "$PROJECT_ID" \
  --commit "$ORIG_HASH" \
  --prompt "$PROMPT" \
  --response "$RESPONSE" \
  --diff "$DIFF" \
  2>>"$HUGININ_DIR/collect.log" || true) &

echo "[huginin] event queued for commit $COMMIT_HASH"
