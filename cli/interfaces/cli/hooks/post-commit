#!/usr/bin/env bash
# HUGININ post-commit hook — collab-proof 기반 고도화
# CI 환경, session.lock, hash-map.json 관리

set -euo pipefail

HUGININ_DIR=".huginin"
LOCK_FILE="$HUGININ_DIR/session.lock"
HASH_MAP="$HUGININ_DIR/hash-map.json"

# CI/CD 환경 자동 스킵
if [ "${CI:-false}" = "true" ] || [ "${GITHUB_ACTIONS:-false}" = "true" ]; then
  exit 0
fi

# huginin CLI 미설치 시 스킵
if ! command -v huginin &>/dev/null; then
  exit 0
fi

# 토큰 미설정 시 스킵
TOKEN=$(huginin __token 2>/dev/null || true)
if [ -z "$TOKEN" ]; then
  exit 0
fi

mkdir -p "$HUGININ_DIR"

# 동시 실행 방지 (session.lock)
if [ -f "$LOCK_FILE" ]; then
  LOCK_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
  if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
    echo "[huginin] another session running (pid $LOCK_PID), skipping"
    exit 0
  fi
fi
echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# 커밋 정보 수집
COMMIT_HASH=$(git rev-parse HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)
DIFF=$(git diff HEAD~1 HEAD --stat 2>/dev/null | head -50 || git diff --cached --stat | head -50)

# hash-map.json: rebase/amend 시 원본 해시 보존
if [ -f "$HASH_MAP" ]; then
  ORIG_HASH=$(python3 -c "
import json, sys
d = json.load(open('$HASH_MAP'))
print(d.get('$COMMIT_HASH', '$COMMIT_HASH'))
" 2>/dev/null || echo "$COMMIT_HASH")
else
  echo '{}' > "$HASH_MAP"
  ORIG_HASH="$COMMIT_HASH"
fi

# .huginin/projects.json 에서 workspace/project 설정 읽기
PROJECTS_FILE="$HUGININ_DIR/projects.json"
if [ ! -f "$PROJECTS_FILE" ]; then
  echo "[huginin] not linked — run: huginin project link"
  exit 0
fi

WORKSPACE_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('workspace_id',''))" 2>/dev/null || true)
PROJECT_ID=$(python3 -c "import json; d=json.load(open('$PROJECTS_FILE')); print(d.get('project_id',''))" 2>/dev/null || true)

if [ -z "$WORKSPACE_ID" ]; then
  echo "[huginin] workspace_id not set in $PROJECTS_FILE"
  exit 0
fi

# 활성 LLM 툴 읽기 (huginin use <tool> 로 설정)
ACTIVE_TOOL=$(python3 -c "
import json, os
try:
    d = json.load(open(os.path.expanduser('~/.huginin/config.json')))
    print(d.get('active_tool', 'claude-code'))
except Exception:
    print('claude-code')
" 2>/dev/null || echo "claude-code")

PROMPT=""
RESPONSE=""

# ── Claude Code 세션 추출 ──────────────────────────────────────────────────
if [ "$ACTIVE_TOOL" = "claude-code" ]; then
  CLAUDE_LOG_DIR="$HOME/.claude/projects"
  # 고정된 활성 세션 파일 우선 사용 (huginin TUI가 기록)
  LATEST=""
  if [ -f "$HUGININ_DIR/active-jsonl" ]; then
    PINNED=$(cat "$HUGININ_DIR/active-jsonl" 2>/dev/null || true)
    [ -f "$PINNED" ] && LATEST="$PINNED"
  fi
  # fallback: 24시간 내 최신 수정 파일
  if [ -z "$LATEST" ] && [ -d "$CLAUDE_LOG_DIR" ]; then
    LATEST=$(find "$CLAUDE_LOG_DIR" -name "*.jsonl" -mmin -1440 2>/dev/null \
      | xargs ls -t 2>/dev/null | head -1 || true)
  fi
  if [ -n "$LATEST" ]; then
      PROMPT=$(python3 -c "
import json, sys

latest_path = sys.argv[1]
lines = []
try:
    with open(latest_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                lines.append(json.loads(line))
            except:
                continue
except:
    pass

turns = []
for l in lines:
    if l.get('type') not in ('user', 'assistant'):
        continue
    msg = l.get('message', {})
    role = msg.get('role')
    content = msg.get('content', '')

    if isinstance(content, str):
        text = content.strip()
    elif isinstance(content, list):
        parts = []
        for c in content:
            if not isinstance(c, dict):
                continue
            if c.get('type') == 'text':
                t = c.get('text', '').strip()
                if t:
                    parts.append(t)
        text = '\n'.join(parts)
    else:
        text = ''

    if text and len(text) > 10:
        turns.append((role, text))

merged = []
for role, text in turns:
    if merged and merged[-1][0] == role:
        merged[-1][1] += '\n' + text
    else:
        merged.append([role, text])

out = []
for role, text in merged:
    label = 'DEV' if role == 'user' else 'AI'
    out.append(f'[{label}] {text[:600]}')

print('\n\n'.join(out)[-8000:])
" "$LATEST" 2>/dev/null || true)
      RESPONSE=""
    fi
  fi
fi

# ── Codex CLI 세션 추출 ────────────────────────────────────────────────────
# ~/.codex/sessions/YYYY/MM/DD/rollout-<ts>-<id>.jsonl
if [ "$ACTIVE_TOOL" = "codex" ]; then
  CODEX_SESSION_DIR="$HOME/.codex/sessions"
  if [ -d "$CODEX_SESSION_DIR" ]; then
    LATEST=$(find "$CODEX_SESSION_DIR" -name "rollout-*.jsonl" -mmin -1440 2>/dev/null \
      | xargs ls -t 2>/dev/null | head -1 || true)
    if [ -n "$LATEST" ]; then
      PROMPT=$(python3 -c "
import json, sys

latest_path = sys.argv[1]
turns = []
try:
    with open(latest_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            if obj.get('type') != 'response_item':
                continue
            payload = obj.get('payload', {})
            if payload.get('type') != 'message':
                continue
            role = payload.get('role', '')
            if role not in ('user', 'assistant'):
                continue
            content = payload.get('content')
            if not isinstance(content, list):
                continue
            parts = []
            for c in content:
                if isinstance(c, dict) and c.get('type') in ('input_text', 'output_text', 'text'):
                    t = c.get('text', '').strip()
                    if t and len(t) > 5:
                        parts.append(t)
            text = '\n'.join(parts)
            if text:
                turns.append((role, text))
except:
    pass

merged = []
for role, text in turns:
    if merged and merged[-1][0] == role:
        merged[-1][1] += '\n' + text
    else:
        merged.append([role, text])

out = []
for role, text in merged:
    label = 'DEV' if role == 'user' else 'AI'
    out.append(f'[{label}] {text[:600]}')

print('\n\n'.join(out)[-8000:])
" "$LATEST" 2>/dev/null || true)
      RESPONSE=""
    fi
  fi
fi

# ── Antigravity CLI (agy) 세션 추출 ──────────────────────────────────────
# ~/.gemini/antigravity-cli/brain/<id>/.system_generated/logs/transcript.jsonl
if [ "$ACTIVE_TOOL" = "antigravity" ]; then
  AGY_BRAIN_DIR="$HOME/.gemini/antigravity-cli/brain"
  if [ -d "$AGY_BRAIN_DIR" ]; then
    LATEST=$(find "$AGY_BRAIN_DIR" -name "transcript.jsonl" -mmin -1440 2>/dev/null \
      | xargs ls -t 2>/dev/null | head -1 || true)
    if [ -n "$LATEST" ]; then
      PROMPT=$(python3 -c "
import json, sys, re

latest_path = sys.argv[1]
turns = []
try:
    with open(latest_path) as f:
        for line in f:
            line = line.strip()
            if not line: continue
            try: obj = json.loads(line)
            except: continue
            src = obj.get('source', '')
            typ = obj.get('type', '')
            content = obj.get('content', '') or ''

            if src == 'USER_EXPLICIT' and typ == 'USER_INPUT':
                # <USER_REQUEST>...</USER_REQUEST> 태그 안의 실제 요청만 추출
                m = re.search(r'<USER_REQUEST>(.*?)</USER_REQUEST>', content, re.DOTALL)
                text = m.group(1).strip() if m else content.strip()
                if text:
                    turns.append(('user', text))
            elif src == 'MODEL' and typ == 'PLANNER_RESPONSE':
                text = content.strip()
                if text:
                    turns.append(('model', text))
except:
    pass

merged = []
for role, text in turns:
    if merged and merged[-1][0] == role:
        merged[-1][1] += '\n' + text
    else:
        merged.append([role, text])

out = []
for role, text in merged:
    label = 'DEV' if role == 'user' else 'AI'
    out.append(f'[{label}] {text[:600]}')

print('\n\n'.join(out)[-8000:])
" "$LATEST" 2>/dev/null || true)
      RESPONSE=""
    fi
  fi
fi

# 세션을 찾지 못하면 커밋 메시지로 대체
if [ -z "$PROMPT" ]; then
  PROMPT="[git commit] $COMMIT_MSG"
fi

# 비동기 업로드 (CLI 블로킹 없이)
(huginin __collect \
  --workspace "$WORKSPACE_ID" \
  --project "$PROJECT_ID" \
  --commit "$ORIG_HASH" \
  --prompt "$PROMPT" \
  --response "$RESPONSE" \
  --diff "$DIFF" \
  --tool "$ACTIVE_TOOL" \
  2>>"$HUGININ_DIR/collect.log" || true) &

echo "[huginin] event queued for commit $COMMIT_HASH"
